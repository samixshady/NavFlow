{
  "name": "navflow-frontend",
  "description": "NavFlow Next.js Frontend",
  "serviceType": "combined",
  "buildSettings": {
    "source": "git",
    "vcsData": {
      "projectType": "github",
      "projectUrl": "https://github.com/samixshady/NavFlow",
      "projectBranch": "main",
      "publicRepo": false
    },
    "dockerfile": {
      "configType": "custom",
      "dockerFilePath": "/Dockerfile.frontend",
      "dockerWorkDir": "/"
    },
    "buildEngine": "buildkit",
    "buildkit": {
      "useInternalCache": false
    }
  },
  "billing": {
    "deploymentPlan": "nf-compute-10"
  },
  "deployment": {
    "instances": 1,
    "region": "europe-west",
    "ports": [
      {
        "name": "web",
        "internalPort": 3000,
        "protocol": "HTTP",
        "public": true,
        "disableNfDomain": false
      }
    ],
    "environmentVariables": [
      {
        "name": "NODE_ENV",
        "value": "production"
      },
      {
        "name": "NEXT_PUBLIC_API_URL",
        "value": "https://p01--navflow-backend--6k8s5s6pktgq.code.run"
      }
    ],
    "storage": {
      "ephemeralStorage": {
        "storageSize": 1024
      },
      "shmSize": 64
    }
  }
}
