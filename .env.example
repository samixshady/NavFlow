# Django Settings
DEBUG=False
# REQUIRED: Generate a secure secret key (DO NOT USE DEFAULTS IN PRODUCTION)
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-generate-a-secure-key

# PostgreSQL Database - Use DATABASE_URL for production
# CRITICAL: Never commit real database credentials!
DATABASE_URL=postgresql://username:password@host:port/dbname?sslmode=require

# Or configure individually (for local development):
# REQUIRED when DATABASE_URL is not provided
DB_ENGINE=django.db.backends.postgresql
DB_NAME=navflow_db
DB_USER=navflow_user
DB_PASSWORD=your-secure-database-password
DB_HOST=localhost
DB_PORT=5432

# JWT Settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_LIFETIME=3600
REFRESH_TOKEN_LIFETIME=86400

# CORS Settings - Update with your Vercel domain
CORS_ALLOWED_ORIGINS=https://nav-flow.vercel.app,http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,testserver,.onrender.com

# Frontend URL
FRONTEND_URL=https://nav-flow.vercel.app

# Render Service URLs
RENDER_BACKEND_URL=your-render-backend-url.onrender.com
