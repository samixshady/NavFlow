# Production Environment Variables
# Copy this to your hosting provider environment variables
# IMPORTANT: Replace ALL placeholder values with actual values - no defaults are used in production

# Django Settings
DEBUG=False
# REQUIRED: Generate a secure secret key (DO NOT USE DEFAULTS)
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-production-secret-key-here-change-this

# Database (REQUIRED - set this to your Neon/Postgres connection string)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Allowed Hosts (add your Render domain)
ALLOWED_HOSTS=your-app-name.onrender.com,localhost

# CORS (add your Vercel frontend domain)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# JWT Settings (optional, uses defaults from settings.py)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_LIFETIME=5
REFRESH_TOKEN_LIFETIME=1440
