# Production Environment Variables - Northflank Deployment
# Copy these values to your Northflank service environment variables
# IMPORTANT: Replace ALL placeholder values with actual values - no defaults are used in production

# Django Settings
DEBUG=False
# REQUIRED: Generate a secure secret key (DO NOT USE DEFAULTS)
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=po@&s%gbz#o_0j!pm1t1l6dw(w7*4=kqbrq5u5)62o@-@%fn^g

# Database (REQUIRED - set this to your Northflank PostgreSQL connection string)
# Format: postgresql://username:password@host:5432/database_name
# Get this from your Northflank PostgreSQL addon details
DATABASE_URL=postgresql://navflow_user:password@your-postgres-addon.northflank.com:5432/navflow_db

# Allowed Hosts (add your Northflank backend domain)
ALLOWED_HOSTS=*.northflank.app,localhost,127.0.0.1

# CORS (add your Northflank frontend domain)
CORS_ALLOWED_ORIGINS=https://navflow-frontend.northflank.app,http://localhost:3000

# Frontend Configuration
NEXT_PUBLIC_API_URL=https://navflow-backend.northflank.app
NODE_ENV=production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_LIFETIME=5
REFRESH_TOKEN_LIFETIME=1440
